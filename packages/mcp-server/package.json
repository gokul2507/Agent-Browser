{
  "name": "@ai-browser/mcp-server",
  "version": "0.1.0",
  "description": "MCP Server for AI Browser — enables Claude Code and LLM agents to browse the web",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ai-browser-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@ai-browser/api": "workspace:*",
    "@ai-browser/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "tsx": "^4.19.0"
  }
}
