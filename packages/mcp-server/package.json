{
  "name": "@agent_browser/mcp-server",
  "version": "0.2.0",
  "description": "MCP Server for AI Browser \u2014 28 tools for AI agents to browse the web via Claude Code",
  "type": "module",
  "license": "MIT",
  "author": "gokul2507",
  "repository": {
    "type": "git",
