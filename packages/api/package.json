{
  "name": "@agent_browser/api",
  "version": "0.2.0",
  "description": "REST API server for AI Browser with dashboard, auth, and rate limiting",
  "type": "module",
  "license": "MIT",
  "author": "gokul2507",
  "repository": {
    "type": "git",
    "url": "https://github.com/gokul2507/Agent-Browser.git",
    "directory": "packages/api"
  },
  "homepage": "https://github.com/gokul2507/Agent-Browser#readme",
  "keywords": [
    "ai",
    "browser",
    "api",
    "rest",
    "dashboard",
    "automation"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ai-browser-api": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts && cp src/dashboard.html dist/",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@agent_browser/core": "workspace:*",
    "fastify": "^5.3.0",
    "@fastify/cors": "^11.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}