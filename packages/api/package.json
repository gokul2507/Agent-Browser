{
  "name": "@ai-browser/api",
  "version": "0.1.0",
  "description": "REST API layer for AI Browser",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts && cp src/dashboard.html dist/",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-browser/core": "workspace:*",
    "fastify": "^5.3.0",
    "@fastify/cors": "^11.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
