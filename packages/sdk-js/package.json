{
  "name": "@agent_browser/sdk",
  "version": "0.2.0",
  "description": "JavaScript/TypeScript SDK for AI Browser \u2014 control a headless browser from your agent",
  "type": "module",
  "license": "MIT",
  "author": "gokul2507",
  "repository": {
    "type": "git",
    "url": "https://github.com/gokul2507/Agent-Browser.git",
    "directory": "packages/sdk-js"
  },
  "homepage": "https://github.com/gokul2507/Agent-Browser#readme",
  "keywords": [
    "ai",
    "browser",
    "sdk",
    "headless",
    "automation",
    "scraping",
    "agent"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.3.0",
    "vitest": "^3.0.0"
  }
}