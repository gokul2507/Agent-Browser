{
  "name": "@agent_browser/core",
  "version": "0.2.6",
  "description": "Core browser engine for AI Browser \u2014 dual engine (Lightpanda + Chromium) abstraction layer",
  "type": "module",
  "license": "MIT",
  "author": "gokul2507",
  "repository": {
    "type": "git",
    "url": "https://github.com/gokul2507/Agent-Browser.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/gokul2507/Agent-Browser#readme",
  "keywords": [
    "ai",
    "browser",
    "headless",
    "lightpanda",
    "chromium",
    "puppeteer",
    "automation",
    "scraping",
    "mcp"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@lightpanda/browser": "^1.2.0",
    "puppeteer": "^24.40.0",
    "puppeteer-core": "^24.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "vitest": "^3.0.0"
  }
}