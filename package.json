{
  "name": "ai-browser",
  "version": "0.1.0",
  "private": true,
  "description": "AI-agent-friendly browser built on Lightpanda",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@lightpanda/browser",
      "esbuild",
      "@biomejs/biome",
      "puppeteer"
    ]
  }
}