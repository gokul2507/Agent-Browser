# Lightpanda browser
LIGHTPANDA_HOST=127.0.0.1
LIGHTPANDA_PORT=9222

# Chromium browser (optional — for heavy SPAs)
CHROMIUM_PATH=
CHROMIUM_HEADLESS=true

# Default engine: lightpanda, chromium, or auto
DEFAULT_ENGINE=lightpanda

# API server
API_HOST=127.0.0.1
API_PORT=3000

# Authentication (optional — leave empty to disable)
API_KEY=

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Logging (debug, info, warn, error)
LOG_LEVEL=info
